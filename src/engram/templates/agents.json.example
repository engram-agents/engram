{
  "_comment": "Multi-agent viz_server config. Used by `viz_server.py --config <this file>`. The viz process needs read access to each listed knowledge.db — the recommended pattern is a shared `agents` POSIX group that owns each agent's $ENGRAM_HOME. Lives at ~/.config/engram-viz/agents.json or /etc/engram-viz/agents.json for systemd-managed installs. The default agent loads when ?agent= is omitted.",
  "agents": [
    {
      "name": "agent-a",
      "label": "Agent A (Claude)",
      "db": "/home/agent-alice/.engram/knowledge.db"
    },
    {
      "name": "agent-b",
      "label": "Agent B (Gemini)",
      "db": "/home/agent-bob/.engram-gemini/knowledge.db"
    }
  ],
  "default": "agent-a"
}
