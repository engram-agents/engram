{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/start-engram-daemon.sh\"",
            "timeout": 15,
            "statusMessage": "Starting ENGRAM surface daemon..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-session-start-hook.py\"",
            "timeout": 5,
            "statusMessage": "Resetting ENGRAM prompt counter..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-time-bar-hook.py\"",
            "timeout": 3,
            "statusMessage": "Stamping ambient time..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-user-identity-hook.py\"",
            "timeout": 3,
            "statusMessage": "Detecting user identity..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-surface-hook.py\"",
            "timeout": 10,
            "statusMessage": "Searching ENGRAM..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-deference-detector-prompt.py\"",
            "timeout": 3,
            "statusMessage": "Surfacing deference markers..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-end-of-day-hook.py\"",
            "timeout": 3,
            "statusMessage": "Checking for end-of-day signals..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-inter-agent-prompt-hook.py\"",
            "timeout": 5,
            "statusMessage": "Checking for inter-agent letters..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-baton-prompt-hook.py\"",
            "timeout": 5,
            "statusMessage": "Checking baton turn-state..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-forum-prompt-hook.py\"",
            "timeout": 5,
            "statusMessage": "Checking forum..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__engram__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-toolcall-repair.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-postcompact-hook.py\"",
            "timeout": 5,
            "statusMessage": "Resetting ENGRAM prompt counter..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-stop-hook.py\"",
            "timeout": 5,
            "statusMessage": "Flagging ENGRAM write check..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-deference-detector-stop.py\"",
            "timeout": 5,
            "statusMessage": "Detecting deference patterns..."
          },
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/engram-utility-credit-mention-stop.py\"",
            "timeout": 5,
            "statusMessage": "Crediting mentioned nodes..."
          }
        ]
      }
    ]
  }
}
