def cmd_init(args):
    """Bootstrap a fresh engram-package skeleton in an empty directory.

    Tolerates a pre-existing `.git` directory (so `mkdir my-pkg && cd my-pkg
    && git init && engram-pkg init .` works as a natural flow). All other
    pre-existing content blocks init to avoid clobbering author work.
    """
    pkg_path = Path(args.path).expanduser().resolve()
    if pkg_path.exists():
        # Filter out .git from the non-empty check — initializing inside an
        # already-`git init`-ed directory is a common author flow.
        existing = [p for p in pkg_path.iterdir() if p.name != ".git"]
        if existing:
            sys.exit(
                f"ERROR: {pkg_path} is not empty (found: "
                f"{', '.join(p.name for p in existing[:5])}"
                f"{'...' if len(existing) > 5 else ''}). "
                f"`engram-pkg init` refuses to overwrite existing files. "
                f"A pre-existing `.git/` is OK; anything else blocks init."
            )
    pkg_path.mkdir(parents=True, exist_ok=True)
    scripts_dir = pkg_path / "scripts"
    scripts_dir.mkdir(exist_ok=True)

    files_written = []

    dump_path = scripts_dir / "dump.sh"
    dump_path.write_text(_DUMP_SH_TEMPLATE)
    dump_path.chmod(0o755)
    files_written.append(("scripts/dump.sh", dump_path))

    build_path = scripts_dir / "build.sh"
    build_path.write_text(_BUILD_SH_TEMPLATE)
    build_path.chmod(0o755)
    files_written.append(("scripts/build.sh", build_path))

    gitignore_path = pkg_path / ".gitignore"
    gitignore_path.write_text(_GITIGNORE_TEMPLATE)
    files_written.append((".gitignore", gitignore_path))

    pkg_name = args.name or pkg_path.name
    readme_path = pkg_path / "README.md"
    readme_path.write_text(_README_TEMPLATE.format(pkg_name=pkg_name))
    files_written.append(("README.md", readme_path))

    # Write config.json with is_knowledge_pack=true before the schema bootstrap
    # so _get_db() skips the seed-node guard. Knowledge-pack DBs legitimately
    # have no seed axioms (they're curated obs/dv sets, not agent brains).
    # Placing this before get_client() ensures _ensure_data_dir() sees the
    # flag and doesn't overwrite it with the default agent config.
    config_path = pkg_path / "config.json"
    config_path.write_text(json.dumps(
        {"schema_version": 2, "is_knowledge_pack": True}, indent=2
    ))
    files_written.append(("config.json", config_path))

    # Bootstrap the schema by triggering the EngramClient once. This creates
    # knowledge.db with the full ENGRAM schema (otherwise build.sh against an
    # empty knowledge.sql produces a schema-less .db that can't be queried).
    # We call engram_stats as a no-op trigger; any read does the same job.
    #
    # ENGRAM_BOOTSTRAP=1 bypasses the server's "DB must exist" startup guard
    # (_get_db()) which would otherwise block schema creation on a fresh package
    # directory — the chicken-and-egg: get_client() needs DB, DB needs client.
    # Same mechanism bootstrap.py uses for seeding. Clear it immediately after
    # so subsequent get_client() calls in the same process use the normal guard.
    _prev_bootstrap = os.environ.get("ENGRAM_BOOTSTRAP")
    os.environ["ENGRAM_BOOTSTRAP"] = "1"
    try:
        client = get_client(pkg_path)
        client.call("engram_stats")
    finally:
        if _prev_bootstrap is None:
            os.environ.pop("ENGRAM_BOOTSTRAP", None)
        else:
            os.environ["ENGRAM_BOOTSTRAP"] = _prev_bootstrap

    # Now dump the schema (no nodes) to knowledge.sql so a fresh
    # `git clone && bash scripts/build.sh` produces a working .db.
    dump_script = pkg_path / "scripts" / "dump.sh"
    rc = subprocess.call(["bash", str(dump_script)],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    if rc != 0:
        sys.exit(f"ERROR: scripts/dump.sh failed during init (rc={rc}). The skeleton was created but knowledge.sql is empty.")
    files_written.append(("knowledge.sql", pkg_path / "knowledge.sql"))

    print(f"Initialized engram-package at {pkg_path}")
    for label, _ in files_written:
        print(f"  + {label}")
    print()
    print("Next steps:")
    print(f"  cd {pkg_path}")
    print(f"  git init && git add . && git commit -m 'init: engram-package skeleton'")
    print(f"  export ENGRAM_PKG={pkg_path}")
    print(f"  engram-pkg add-evidence --url ... --title ...")
    return 0


# Path prefixes that almost certainly indicate a machine-local URL, not
# something a different consumer can resolve. Order doesn't matter; any
# match triggers the warning.
_LOCAL_URL_INDICATORS = (
    "file:///home/", "file:///Users/", "file:///root/",
    "file:///tmp/", "file:///var/",
)


def _warn_if_local_url(url: str) -> None:
    """Emit a stderr warning when url looks machine-local (won't port to
    other consumers of the package). Non-blocking — the URL is still accepted.
    """
    if not url:
        return
    if not any(url.startswith(prefix) for prefix in _LOCAL_URL_INDICATORS):
        return
    sys.stderr.write(
        f"WARNING: URL '{url}' looks like a machine-local absolute path. "
        f"Other consumers of this package will not be able to resolve it. "
        f"Consider a stable URL instead: GitHub raw "
        f"(https://raw.githubusercontent.com/...), a project-relative path, "
        f"or arxiv/DOI for published sources.\n"
    )


def _load_json_payload(raw: str) -> dict:
    try:
        return json.loads(raw)
    except json.JSONDecodeError as e:
        sys.exit(f"ERROR: invalid JSON payload: {e}")


def cmd_add_evidence(args):
    client = get_client(resolve_pkg(args))
    if args.json_payload is not None:
        raw = sys.stdin.read() if args.json_payload == "-" else args.json_payload
        payload = _load_json_payload(raw)
    else:
        if not args.url or not args.title:
            sys.exit("ERROR: --url and --title required (or pass a JSON payload as the first positional argument).")
        _warn_if_local_url(args.url)
        payload = {
            "url": args.url, "title": args.title,
            "domain": args.domain or "", "source_date": args.source_date or "",
        }
    return report(client.call("engram_add_evidence", payload))


def cmd_add_observation(args):
    client = get_client(resolve_pkg(args))
    if args.json_payload is not None:
        raw = sys.stdin.read() if args.json_payload == "-" else args.json_payload
        payload = _load_json_payload(raw)
    else:
        if not args.quoted_text or not args.interpretation or not args.claim or not args.quote_type:
            sys.exit("ERROR: --quoted-text, --interpretation, --claim, --quote-type required (or pass a JSON payload as the first positional argument).")
        payload = {
            "quoted_text": args.quoted_text,
            "interpretation": args.interpretation,
            "claim": args.claim,
            "quote_type": args.quote_type,
        }
        if args.evidence_id:
            payload["evidence_id"] = args.evidence_id
        elif args.url:
            _warn_if_local_url(args.url)
            payload["url"] = args.url
            payload["title"] = args.title or ""
            if args.source_date:
                payload["source_date"] = args.source_date
        else:
            sys.exit("ERROR: provide --evidence-id OR --url --title.")
        if args.source_class:
            payload["source_class"] = args.source_class
    return report(client.call("engram_add_observation", payload))


