def resolve_pkg(args):
    pkg = args.pkg or os.environ.get("ENGRAM_PKG")
    if not pkg:
        sys.exit("ERROR: --pkg required (or set $ENGRAM_PKG). Point at an engram-package directory.")
    pkg_path = Path(pkg).expanduser().resolve()
    if not pkg_path.is_dir():
        sys.exit(f"ERROR: {pkg_path} is not a directory.")
    return pkg_path


# 5-second slack absorbs filesystem mtime jitter (touch-modify within the same
# second, build script mtime updates near-simultaneously, etc.). Anything past
# 5s of sql-newer-than-db is a real authoring gap.
_STALE_SLACK_SECS = 5


def _check_stale_build(pkg_path, auto_build=False):
    """Detect knowledge.sql newer than knowledge.db.

    Direction matters: db-newer-than-sql is the normal mid-authoring state
    (CLI write commands hit .db; `dump` catches .sql up). The reverse is the
    one that produces silent stale reads — typically after a fresh git pull
    or a hand-edit of knowledge.sql without `engram-pkg build`.
    """
    db = pkg_path / "knowledge.db"
    sql = pkg_path / "knowledge.sql"
    if not (db.exists() and sql.exists()):
        return
    if sql.stat().st_mtime <= db.stat().st_mtime + _STALE_SLACK_SECS:
        return
    if auto_build:
        script = pkg_path / "scripts" / "build.sh"
        if script.exists():
            sys.stderr.write(
                "NOTE: knowledge.sql newer than knowledge.db — auto-building...\n"
            )
            rc = subprocess.call(["bash", str(script)])
            if rc != 0:
                sys.exit(f"ERROR: auto-build failed (rc={rc}). Run `engram-pkg build` manually to see errors.")
        else:
            # Hard-exit instead of degrading to a stale read. The user
            # explicitly passed --auto-build because they did NOT want
            # to read stale data; warn-and-continue would silently
            # contradict that intent.
            sys.exit(
                f"ERROR: --auto-build requested but {script} not found. "
                f"Run `engram-pkg build` manually, or remove --auto-build "
                f"to fall back to warn-only mode."
            )
        return
    sys.stderr.write(
        f"WARNING: knowledge.sql is newer than knowledge.db — read commands "
        f"may return stale data. Run `engram-pkg build` to refresh, or pass "
        f"--auto-build to do it automatically.\n"
    )


def _ensure_pkg_config(pkg_path: Path) -> None:
    """Write or update config.json to include is_knowledge_pack=true.

    Runs before every EngramClient construction so the _get_db() seed-node
    guard sees the flag and skips the axiom-count check. Knowledge-pack DBs
    legitimately have no seed axioms; the flag distinguishes them from a
    crashed personal-install bootstrap (#695).

    Handles three cases:
      - No config.json: writes a minimal one (schema_version + flag).
      - Existing config without flag: adds flag in-place.
      - Existing config with flag already set: no-op.
    """
    config_path = pkg_path / "config.json"
    if config_path.exists():
        try:
            cfg = json.loads(config_path.read_text(encoding="utf-8"))
            if not cfg.get("is_knowledge_pack"):
                cfg["is_knowledge_pack"] = True
                config_path.write_text(json.dumps(cfg, indent=2))
        except Exception:
            pass
    else:
        config_path.write_text(json.dumps(
            {"schema_version": 2, "is_knowledge_pack": True}, indent=2
        ))


def get_client(pkg_path):
    _ensure_pkg_config(Path(pkg_path))
    sys.path.insert(0, str(REPO_ROOT))
    from engram_client import EngramClient  # noqa: E402
    return EngramClient(db_dir=str(pkg_path), server_module_path=str(REPO_ROOT))


def report(result):
    """Pretty-print a tool result; exit non-zero on error."""
    if isinstance(result, dict) and "error" in result:
        sys.exit(f"ERROR: {result['error']}")
    print(json.dumps(result, indent=2, ensure_ascii=False))
    return 0


