_DUMP_SH_TEMPLATE = '''#!/usr/bin/env bash
# Dump the local knowledge.db to knowledge.sql for git-versioned commit.
# Author-side only — runs after authoring sessions, before `git commit knowledge.sql`.
# (Consumers do not need this script. They run scripts/build.sh after pull.)

set -euo pipefail

PKG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DB_FILE="$PKG_DIR/knowledge.db"
SQL_FILE="$PKG_DIR/knowledge.sql"

if [[ ! -f "$DB_FILE" ]]; then
    echo "ERROR: $DB_FILE not found. Run scripts/build.sh first (or seed it via engram-pkg)." >&2
    exit 1
fi

# WAL flush + virtual-table-safe SQL dump — pure-Python, no sqlite3 CLI needed (#799).
# Rebuilds an in-memory copy from only the real (non-virtual) tables so iterdump()
# never encounters FTS5/vec0 virtual tables that require unloaded extensions (#799).
python3 - "$DB_FILE" "$SQL_FILE" <<'ENGRAM_DUMP'
import sys, sqlite3
db_file, sql_file = sys.argv[1], sys.argv[2]
src = sqlite3.connect(db_file)
src.execute("PRAGMA wal_checkpoint(TRUNCATE)")
src.commit()
# Collect schema — ORDER BY rowid preserves creation order (tables before indexes).
schema = src.execute(
    "SELECT type, name, sql FROM sqlite_master ORDER BY rowid"
).fetchall()
# Virtual tables: sql starts with CREATE VIRTUAL TABLE (case-insensitive).
virtual = {name for t, name, sql in schema
           if t == "table" and sql is not None
           and sql.upper().lstrip().startswith("CREATE VIRTUAL TABLE")}
# Shadow tables: name starts with "<virtual_name>_" for any virtual table.
pfxs = tuple(v + "_" for v in virtual)
shadow = {name for t, name, sql in schema
          if t == "table" and any(name.startswith(p) for p in pfxs)}
# sqlite_* system tables are auto-managed by SQLite; skip them in CREATE.
skip_tables = virtual | shadow | {name for t, name, sql in schema if name.startswith("sqlite_")}
# Triggers referencing any virtual table.
skip_trg = {name for t, name, sql in schema
            if t == "trigger" and sql is not None
            and any(v in sql for v in virtual)}
# Rebuild in-memory DB with only the real tables + indexes + safe triggers.
bk = sqlite3.connect(":memory:")
for t, name, sql in schema:
    if sql is None:
        continue
    if t in ("table", "shadow") and name in skip_tables:
        continue
    if t == "trigger" and name in skip_trg:
        continue
    bk.execute(sql)
bk.commit()
# Copy data row-by-row for each included real table.
for t, name, sql in schema:
    if t != "table" or name in skip_tables or sql is None:
        continue
    rows = src.execute(f"SELECT * FROM [{name}]").fetchall()
    if rows:
        bk.executemany(
            f"INSERT INTO [{name}] VALUES ({','.join('?' * len(rows[0]))})", rows
        )
bk.commit()
src.close()
with open(sql_file, "w") as f:
    for line in bk.iterdump():
        print(line, file=f)
bk.close()
ENGRAM_DUMP

NODE_COUNT=$(python3 -c "import sys,sqlite3; c=sqlite3.connect(sys.argv[1]); print(c.execute('SELECT COUNT(*) FROM nodes').fetchone()[0]); c.close()" "$DB_FILE")
SQL_LINES=$(wc -l < "$SQL_FILE")
echo "Dumped $DB_FILE -> $SQL_FILE  ($NODE_COUNT nodes, $SQL_LINES lines)"
echo "Review diff with: git diff knowledge.sql"
'''

