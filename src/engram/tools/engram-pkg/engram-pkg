# Default size-guard thresholds.  Configurable via --max-nodes / --max-edges.
_SCOPE_EXPORT_DEFAULT_MAX_NODES = 200
_SCOPE_EXPORT_DEFAULT_MAX_EDGES = 400


def _load_source_agent_name(source_db_dir: Path) -> str:
    """Read agent_name from the source config.json (falls back to 'unknown')."""
    cfg = source_db_dir / "config.json"
    if cfg.exists():
        try:
            data = json.loads(cfg.read_text())
            name = data.get("agent_name") or data.get("agent-name") or ""
            if name:
                return name
        except (json.JSONDecodeError, OSError):
            pass
    return "unknown"


def _compute_provenance_closure(
    source_conn: sqlite3.Connection,
    root_ids: list[str],
    max_nodes: int,
    max_edges: int,
) -> tuple[dict, list[dict]]:
    """Compute the transitive provenance closure from the given root IDs.

    Traversal rule (spec §3):
      - Follows all outgoing edges from each included node (derives_from,
        supports, cites, evidence links, supersedes, contradicts, resolves).
      - Also includes incoming edges that touch included nodes (so the
        reader sees the node's epistemic status).
      - Stops at natural provenance leaves (axioms, definitions, evidence
        nodes with no further outgoing edges, observations-with-evidence).
      - Includes ALL edges where both endpoints are in the closure (§3a).

    The BFS visits ALL reachable nodes via outgoing edges first (provenance
    direction = toward sources), then picks up any incoming edges to already-
    included nodes so supersedes/contradicts/resolves arcs are visible.

    Returns:
        (nodes_dict, edges_list):
            nodes_dict: {node_id: row_dict} — full row for every included node
            edges_list: list of edge row dicts where BOTH endpoints are included

    Raises SystemExit on size-guard violation (never silently truncates).
    """
    source_conn.row_factory = sqlite3.Row

    # BFS over outgoing provenance edges to discover the closure.
    visited: dict[str, dict] = {}
    queue: collections.deque = collections.deque(root_ids)

    # Validate all root IDs exist before starting.
    missing = []
    for rid in root_ids:
        row = source_conn.execute("SELECT * FROM nodes WHERE id = ?", (rid,)).fetchone()
        if row is None:
            missing.append(rid)
    if missing:
        sys.exit(
            f"ERROR: scope-export: root node(s) not found in source graph: "
            f"{', '.join(missing)}"
        )

    while queue:
        nid = queue.popleft()
        if nid in visited:
            continue
        row = source_conn.execute("SELECT * FROM nodes WHERE id = ?", (nid,)).fetchone()
        if row is None:
            # Referenced but doesn't exist (stale edge in source) — skip.
            continue
        visited[nid] = dict(row)

        # Size-guard check — fail loudly, never truncate.
        if len(visited) > max_nodes:
            sys.exit(
                f"ERROR: scope-export: closure exceeded size guard "
                f"({max_nodes} nodes max). The root set is too broad; "
                f"narrow the --nodes list and re-run. "
                f"(Use --max-nodes to adjust the threshold.)"
            )

        # Follow outgoing edges (toward provenance sources).
        outgoing = source_conn.execute(
            "SELECT * FROM edges WHERE source_id = ?", (nid,)
        ).fetchall()
        for e in outgoing:
            tgt = e["target_id"]
            if tgt not in visited:
                queue.append(tgt)

    # Now collect ALL edges where BOTH endpoints are in the closure.
    # This includes:
    #   (a) outgoing edges from included nodes → included targets (provenance)
    #   (b) incoming edges to included nodes from other included nodes
    #       (e.g. supersedes, contradicts, resolves arcs)
    # Using a single query for efficiency.
    node_ids_tuple = tuple(visited.keys())
    if not node_ids_tuple:
        return visited, []

    # SQLite has a max 999 params per query; chunk if needed.
    all_edges: list[dict] = []
    if len(node_ids_tuple) <= 990:
        placeholders = ",".join("?" * len(node_ids_tuple))
        rows = source_conn.execute(
            f"SELECT * FROM edges WHERE source_id IN ({placeholders}) "
            f"AND target_id IN ({placeholders})",
            node_ids_tuple + node_ids_tuple,
        ).fetchall()
        all_edges = [dict(r) for r in rows]
    else:
        # Large closure: scan all edges and filter in Python.
        node_set = set(visited.keys())
        for row in source_conn.execute("SELECT * FROM edges").fetchall():
            if row["source_id"] in node_set and row["target_id"] in node_set:
                all_edges.append(dict(row))

    # Deduplicate by (source_id, target_id, relation).
    seen: set[tuple] = set()
    unique_edges: list[dict] = []
    for e in all_edges:
        key = (e["source_id"], e["target_id"], e["relation"])
        if key not in seen:
            seen.add(key)
            unique_edges.append(e)

    # Size-guard on edges.
    if len(unique_edges) > max_edges:
        sys.exit(
            f"ERROR: scope-export: closure exceeded edge size guard "
            f"({max_edges} edges max). The root set is too broad; "
            f"narrow the --nodes list and re-run. "
            f"(Use --max-edges to adjust the threshold.)"
        )

    return visited, unique_edges


def _find_dangling_edges(
    nodes: dict, edges: list[dict]
) -> list[tuple[str, str, str]]:
    """Return a list of (src, tgt, relation) for edges with an endpoint outside nodes.

    Pure checker — no I/O, no sys.exit, no side effects.  Returns an empty list
    when the closure is complete.  The wrapper _assert_closure_completeness
    calls this and exits on violation; callers that need to handle violations
    programmatically (e.g. server-side validation) call this directly.
    """
    node_set = set(nodes.keys())
    dangling = []
    for e in edges:
        src, tgt = e["source_id"], e["target_id"]
        if src not in node_set or tgt not in node_set:
            dangling.append((src, tgt, e["relation"]))
    return dangling


def _assert_closure_completeness(nodes: dict, edges: list[dict]) -> None:
    """Assert the closure-completeness invariant (spec §3a).

    Every edge in the pack must have BOTH endpoints in the pack.
    Raises SystemExit with a clear message on violation.

    This is a hard guard — not advisory.  A dangling edge is silent-wrong
    on the consume side (see §3a rationale).

    Thin wrapper around _find_dangling_edges for the CLI exit path; callers
    that need to handle violations programmatically should call
    _find_dangling_edges directly.
    """
    dangling = _find_dangling_edges(nodes, edges)
    if dangling:
        examples = "; ".join(f"{s} →[{r}]→ {t}" for s, t, r in dangling[:5])
        sys.exit(
            f"ERROR: scope-export: closure-completeness invariant violated — "
            f"{len(dangling)} edge(s) have an endpoint outside the pack. "
            f"Examples: {examples}. "
            f"This is a bug in the closure logic; please report it."
        )


def _sql_literal(v) -> str:
    """Serialize a Python value as a SQL literal (NULL, integer, real, or quoted string)."""
    if v is None:
        return "NULL"
    elif isinstance(v, int):
        return str(v)
    elif isinstance(v, float):
        return repr(v)  # repr avoids lossy .6f rounding for floats like confidence
    else:
        # Escape single quotes by doubling them.
        return "'" + str(v).replace("'", "''") + "'"


def _write_canonical_knowledge_sql(pkg_db_path: Path, sql_out_path: Path) -> bytes:
    """Produce a self-contained, deterministic knowledge.sql from the package DB.

    The output is pipeable into a fresh sqlite3 db (via scripts/build.sh) and
    produces a complete, queryable engram-package db.  Round-1 only emitted
    INSERT statements, which broke the build.sh consumer path ("no such table:
    nodes").  This version emits full DDL (CREATE TABLE / CREATE INDEX /
    CREATE TRIGGER) before the data INSERTs, derived from sqlite_master so the
    schema definition stays in sync with whatever the source db was initialised
    with — never hand-invented here.

    DDL inclusion decisions:
      INCLUDED  — nodes, edges, sequences, edit_history, diagnostic_history,
                  tool_timing, focus_sets, focus_state (full schema, empty
                  runtime tables included so EngramClient can operate against
                  the built db without migration errors), plus nodes_fts FTS5
                  virtual table + its triggers (FTS5 is built into SQLite's
                  standard amalgamation, plain sqlite3 handles it fine).
      EXCLUDED  — vec_nodes and all vec_* shadow tables: require the sqlite-vec
                  extension (vec0 module) which is NOT available in a standard
                  sqlite3 binary.  Embedding-dependent search degrades silently
                  to FTS5 + keyword fallback; the core claim/evidence graph is
                  fully present.  See comment in cmd_scope_export for context.
      EXCLUDED  — nodes_fts shadow tables (nodes_fts_config, nodes_fts_data,
                  nodes_fts_docsize, nodes_fts_idx, nodes_fts_vocab): these are
                  internal implementation tables created automatically by SQLite
                  when the VIRTUAL TABLE is created; explicitly emitting them
                  causes "object name reserved for internal use" errors.
      EXCLUDED  — sqlite_sequence, sqlite_autoindex_*: auto-managed by SQLite;
                  emitting them is either a no-op or an error.

    Emit order (required for correct FK dependency resolution):
      1. nodes (no FK deps)
      2. edges, sequences, edit_history, diagnostic_history, tool_timing,
         focus_sets, focus_state (after nodes)
      3. nodes_fts VIRTUAL TABLE (must come after nodes; it uses
         content='nodes' external content table)
      4. Indexes (ORDER BY name for determinism)
      5. Triggers (ORDER BY name; depend on nodes_fts existing)
      6. Data INSERTs: nodes ORDER BY id, edges ORDER BY id,
         sequences ORDER BY node_type

    Returns the raw bytes written (used for sha256 content_hash).
    Deterministic: re-running on the same closure → identical bytes.
    """
    conn = sqlite3.connect(str(pkg_db_path))
    conn.row_factory = sqlite3.Row
    lines: list[str] = []

    lines.append("-- engram-package canonical dump")
    lines.append(
        "-- Generated by engram-pkg scope-export (schema + deterministic ORDER BY id data)"
    )
    lines.append("PRAGMA foreign_keys=OFF;")
    lines.append("BEGIN TRANSACTION;")

    # ------------------------------------------------------------------ #
    # DDL Section 1 — regular tables in dependency order.                  #
    # ------------------------------------------------------------------ #
    # nodes must come first (edges FK-references nodes).
    # The remaining tables have no FK deps on each other and can appear in
    # any order, but we use a stable fixed list for determinism.
    _TABLE_EMIT_ORDER = [
        "nodes",
        "edges",
        "sequences",
        "edit_history",
        "diagnostic_history",
        "tool_timing",
        "focus_sets",
        "focus_state",
    ]
    for tname in _TABLE_EMIT_ORDER:
        row = conn.execute(
            "SELECT sql FROM sqlite_master WHERE type='table' AND name=?", (tname,)
        ).fetchone()
        if row and row["sql"]:
            lines.append(row["sql"] + ";")

    # ------------------------------------------------------------------ #
    # DDL Section 2 — FTS5 virtual table (after nodes; content='nodes').  #
    # Shadow tables (nodes_fts_config, etc.) are auto-created by SQLite   #
    # and MUST NOT be emitted here — doing so raises                      #
    # "object name reserved for internal use".                            #
    # ------------------------------------------------------------------ #
    row = conn.execute(
        "SELECT sql FROM sqlite_master WHERE type='table' AND name='nodes_fts'"
    ).fetchone()
    if row and row["sql"]:
        lines.append(row["sql"] + ";")

    # ------------------------------------------------------------------ #
    # DDL Section 3 — indexes (ORDER BY name for determinism).            #
    # Exclude sqlite-internal autoindex names.                            #
    # ------------------------------------------------------------------ #
    for row in conn.execute(
        "SELECT sql FROM sqlite_master "
        "WHERE type='index' AND name NOT LIKE 'sqlite%' "
        "ORDER BY name"
    ).fetchall():
        if row["sql"]:
            lines.append(row["sql"] + ";")

    # ------------------------------------------------------------------ #
    # DDL Section 4 — triggers (ORDER BY name for determinism).           #
    # These recreate the FTS5 insert/delete/retract triggers.             #
    # ------------------------------------------------------------------ #
    for row in conn.execute(
        "SELECT sql FROM sqlite_master WHERE type='trigger' ORDER BY name"
    ).fetchall():
        if row["sql"]:
            lines.append(row["sql"] + ";")

    # ------------------------------------------------------------------ #
    # Data Section — nodes, edges, sequences (all ORDER BY for           #
    # determinism; same closure run → byte-identical output).             #
    # ------------------------------------------------------------------ #

    # --- nodes table ---
    col_info = conn.execute("PRAGMA table_info(nodes)").fetchall()
    node_cols = [r["name"] for r in col_info]
    col_list = ", ".join(node_cols)

    for row in conn.execute(f"SELECT {col_list} FROM nodes ORDER BY id").fetchall():
        sql_vals = [_sql_literal(v) for v in list(row)]
        lines.append(f"INSERT INTO nodes ({col_list}) VALUES ({', '.join(sql_vals)});")

    # --- edges table ---
    edge_col_info = conn.execute("PRAGMA table_info(edges)").fetchall()
    edge_cols = [r["name"] for r in edge_col_info]
    edge_col_list = ", ".join(edge_cols)

    for row in conn.execute(
        f"SELECT {edge_col_list} FROM edges ORDER BY id"
    ).fetchall():
        sql_vals = [_sql_literal(v) for v in list(row)]
        lines.append(
            f"INSERT INTO edges ({edge_col_list}) VALUES ({', '.join(sql_vals)});"
        )

    # --- sequences table ---
    for row in conn.execute(
        "SELECT node_type, last_num FROM sequences ORDER BY node_type"
    ).fetchall():
        nt = _sql_literal(row["node_type"])
        lines.append(
            f"INSERT INTO sequences (node_type, last_num) VALUES ({nt}, {row['last_num']});"
        )

    lines.append("COMMIT;")
    conn.close()

    content = "\n".join(lines) + "\n"
    raw_bytes = content.encode("utf-8")
    sql_out_path.write_bytes(raw_bytes)
    return raw_bytes


def _populate_package_db(pkg_db_path: Path, nodes: dict, edges: list[dict]) -> None:
    """Insert closure nodes and edges into the (already-schema'd) package DB.

    Uses direct SQL INSERT preserving all columns from the source rows.
    The package DB was bootstrapped by cmd_init (full schema present).
    """
    conn = sqlite3.connect(str(pkg_db_path))
    conn.row_factory = sqlite3.Row
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA foreign_keys=OFF")  # Avoid FK constraint on insert order.

    # Get package DB column names (may differ from source if schema evolved).
    pkg_node_cols = {r[1] for r in conn.execute("PRAGMA table_info(nodes)").fetchall()}
    pkg_edge_cols = {r[1] for r in conn.execute("PRAGMA table_info(edges)").fetchall()}

    for nid, node_row in nodes.items():
        # Only insert columns that exist in the package schema.
        filtered = {k: v for k, v in node_row.items() if k in pkg_node_cols}
        if not filtered:
            continue
        cols = ", ".join(filtered.keys())
        placeholders = ", ".join("?" * len(filtered))
        vals = list(filtered.values())
        conn.execute(
            f"INSERT OR REPLACE INTO nodes ({cols}) VALUES ({placeholders})",
            vals,
        )

    for edge_row in edges:
        # Skip the autoincrement id — the package DB will assign its own.
        filtered = {
            k: v for k, v in edge_row.items()
            if k in pkg_edge_cols and k != "id"
        }
        if not filtered:
            continue
        cols = ", ".join(filtered.keys())
        placeholders = ", ".join("?" * len(filtered))
        vals = list(filtered.values())
        conn.execute(
            f"INSERT OR IGNORE INTO edges ({cols}) VALUES ({placeholders})",
            vals,
        )

    # Update sequences so the package knows the highest ID per type.
    for nid in nodes:
        if "_" in nid:
            prefix = nid.rsplit("_", 1)[0]
            try:
                num = int(nid.rsplit("_", 1)[1])
            except ValueError:
                continue
            conn.execute(
                """
                INSERT INTO sequences (node_type, last_num) VALUES (?, ?)
                ON CONFLICT(node_type) DO UPDATE
                    SET last_num = MAX(sequences.last_num, excluded.last_num)
                """,
                (prefix, num),
            )

    conn.commit()
    conn.close()


def cmd_scope_export(args):
    """Export a provenance closure as a scoped engram-package + sidecar manifest.

    Steps (per spec §6):
      (a) Compute the transitive provenance closure from --nodes root IDs,
          reading the agent's live ~/.engram/knowledge.db read-only.
      (b) Validate closure-completeness invariant (spec §3a) — hard-fail on
          any dangling edge.
      (c) engram-pkg init a fresh package dir at --out.
      (d) Populate the package DB with closure nodes + edges via direct SQL.
      (e) Write a deterministic canonical knowledge.sql (ORDER BY id).
      (f) Compute sha256(knowledge.sql bytes) and write manifest.json (spec §4).
    """
    root_ids = [r.strip() for r in args.nodes.split(",") if r.strip()]
    if not root_ids:
        sys.exit("ERROR: scope-export: --nodes must be a non-empty comma-separated list of node IDs.")

    out_path = Path(args.out).expanduser().resolve()

    # Locate the source DB (agent's personal graph, read-only).
    source_home = Path(
        os.environ.get("ENGRAM_HOME") or os.path.expanduser("~/.engram")
    ).expanduser().resolve()
    source_db = source_home / "knowledge.db"
    if not source_db.exists():
        sys.exit(
            f"ERROR: scope-export: source graph not found at {source_db}. "
            f"Set $ENGRAM_HOME to point at your ENGRAM data directory."
        )

    max_nodes = args.max_nodes if args.max_nodes is not None else _SCOPE_EXPORT_DEFAULT_MAX_NODES
    max_edges = args.max_edges if args.max_edges is not None else _SCOPE_EXPORT_DEFAULT_MAX_EDGES

    # (a) Compute provenance closure from the source DB (read-only).
    print(f"scope-export: computing closure from {source_db} ...")
    source_conn = sqlite3.connect(f"file:{source_db}?mode=ro", uri=True)
    source_conn.row_factory = sqlite3.Row
    try:
        nodes, edges = _compute_provenance_closure(
            source_conn, root_ids, max_nodes, max_edges
        )
    finally:
        source_conn.close()

    # (b) Closure-completeness invariant (spec §3a).
    _assert_closure_completeness(nodes, edges)

    node_count = len(nodes)
    edge_count = len(edges)
    print(f"scope-export: closure = {node_count} nodes, {edge_count} edges")

    # (c) Bootstrap a fresh package dir via cmd_init (reuse its logic).
    # We need to call init without touching --pkg (init takes a positional path).
    # Construct a namespace that mimics what cmd_init expects.
    import types as _types
    init_args = _types.SimpleNamespace(path=str(out_path), name=args.name or out_path.name)
    cmd_init(init_args)

    # (d) Populate the package DB with closure nodes + edges.
    pkg_db = out_path / "knowledge.db"
    if not pkg_db.exists():
        sys.exit(f"ERROR: scope-export: package DB not found at {pkg_db} after init.")
    print(f"scope-export: populating package DB ...")
    _populate_package_db(pkg_db, nodes, edges)

    # (e) Write deterministic canonical knowledge.sql.
    sql_path = out_path / "knowledge.sql"
    print(f"scope-export: writing canonical knowledge.sql ...")
    sql_bytes = _write_canonical_knowledge_sql(pkg_db, sql_path)

    # (f) Hash knowledge.sql and write manifest.json (spec §4).
    content_hash = "sha256:" + hashlib.sha256(sql_bytes).hexdigest()

    # Read schema version from the package config.json (written by init).
    pkg_cfg_path = out_path / "config.json"
    schema_version = "unknown"
    if pkg_cfg_path.exists():
        try:
            pkg_cfg = json.loads(pkg_cfg_path.read_text())
            schema_version = str(pkg_cfg.get("schema_version", "unknown"))
        except (json.JSONDecodeError, OSError):
            pass

    author_agent = _load_source_agent_name(source_home)
    created_at = datetime.datetime.now(datetime.timezone.utc).strftime(
        "%Y-%m-%dT%H:%M:%SZ"
    )

    manifest = {
        "pack_format": "engram-package/v1",
        "root_node_ids": root_ids,
        "node_count": node_count,
        "edge_count": edge_count,
        "author_agent": author_agent,
        "content_hash": content_hash,
        "engram_schema_version": schema_version,
        "created_at": created_at,
        "answer_post_id": None,
    }
    manifest_path = out_path / "manifest.json"
    manifest_path.write_text(json.dumps(manifest, indent=2, ensure_ascii=False) + "\n")

    print(f"scope-export: wrote manifest.json")
    print(f"scope-export: done.")
    print(f"")
    print(f"Output: {out_path}")
    print(f"  nodes:         {node_count}")
    print(f"  edges:         {edge_count}")
    print(f"  roots:         {', '.join(root_ids)}")
    print(f"  content_hash:  {content_hash}")
    print(f"  author_agent:  {author_agent}")
    return 0


def cmd_call(args):
    """Generic escape hatch — invoke any engram_* tool with JSON-encoded args.

    Two input paths for the params dict:
      --json '<inline JSON>'         — quick one-liners; subject to shell quoting.
      --json-file <path>             — read JSON from a file; sidesteps shell
                                       quoting entirely (recommended for any
                                       payload with backticks, apostrophes,
                                       or multi-line prose).

    Mutually exclusive. If neither is provided, payload is empty (some tools
    accept no args, e.g. engram_reflect).
    """
    if args.json and args.json_file:
        sys.exit("ERROR: --json and --json-file are mutually exclusive.")

    if args.json_file:
        path = Path(args.json_file).expanduser()
        if not path.is_file():
            sys.exit(f"ERROR: --json-file {path} not found.")
        try:
            payload = json.loads(path.read_text())
        except json.JSONDecodeError as e:
            sys.exit(f"ERROR: --json-file {path} contains invalid JSON: {e}")
    elif args.json:
        try:
            payload = json.loads(args.json)
        except json.JSONDecodeError as e:
            sys.exit(f"ERROR: --json invalid: {e}")
    else:
        payload = {}

    if not isinstance(payload, dict):
        sys.exit(f"ERROR: payload must be a JSON object (dict), got {type(payload).__name__}.")

    client = get_client(resolve_pkg(args))
    return report(client.call(args.tool_name, payload))


