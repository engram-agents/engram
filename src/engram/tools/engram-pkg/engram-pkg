def cmd_supersede(args):
    """Wire two existing nodes via supersede relation.

    engram_supersede is RELATIONAL ONLY — it does not create the
    replacement node. Workflow:
      1. Create the new node via add-observation / derive / etc.
      2. engram-pkg supersede --old-node-id <old> --new-node-id <new>
         [--reason <short rationale>]
         OR: engram-pkg supersede '{"old_node_id":"<old>","new_node_id":"<new>"}'
    """
    client = get_client(resolve_pkg(args))
    if args.json_payload is not None:
        raw = sys.stdin.read() if args.json_payload == "-" else args.json_payload
        payload = _load_json_payload(raw)
    else:
        if not args.old_node_id or not args.new_node_id:
            sys.exit("ERROR: --old-node-id and --new-node-id required (or pass a JSON payload as the first positional argument).")
        payload = {
            "old_node_id": args.old_node_id,
            "new_node_id": args.new_node_id,
        }
        if args.reason:
            payload["supersede_reason"] = args.reason
    return report(client.call("engram_supersede", payload))


